{
	"version": 3,
	"configurePresets": [
		{
			"name": "linux-default",
			"hidden": true,
			"generator": "Unix Makefiles",
			"binaryDir": "_build/${presetName}",
			"environment": {
				"CXX_WARNINGS": "-Wall -Wextra -Wpedantic -Werror"
			},
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "$env{CXX_WARNINGS} $env{CXX_OPT}"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": "windows-default",
			"hidden": true,
			"architecture": "x64",
			"binaryDir": "_build/${presetName}",
			"environment": {
				"CXX_WARNINGS": "/W3",
				"CXX_OPT": "/DWIN32 /D_WINDOWS /GR /EHsc /permissive-"
			},
			"cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install",
				"CMAKE_CXX_FLAGS": "$env{CXX_WARNINGS} $env{CXX_OPT}",
				"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET":  "x64-windows-static-md"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "vs2022",
			"displayName": "vs2022",
			"inherits": "windows-default",
			"generator": "Visual Studio 17 2022"
		},
		{
			"name": "clang-cl-debug",
			"displayName": "Clang-CL Debug",
			"architecture": "x64",
			"generator": "Visual Studio 17 2022",
			"binaryDir": "_build/${presetName}",
			"toolset":  "ClangCL",
			"environment": {
				"CXX_WARNINGS": "/W3 /wd4127 /wd4224",
				"CXX_OPT": "/DWIN32 /D_WINDOWS /GR /EHsc /fp:strict /permissive-",
				"VCPKG_ROOT":  "C:/Tools/vcpkg"
			},
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "$env{CXX_WARNINGS} $env{CXX_OPT}",
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET":  "x64-windows-static-md"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "clang-cl-release",
			"displayName": "Clang-CL Release",
			"architecture": "x64",
			"generator": "Visual Studio 17 2022",
			"binaryDir": "_build/${presetName}",
			"toolset":  "ClangCL",
			"environment": {
				"CXX_WARNINGS": "/W3 /wd4127 /wd4224",
				"XCXX_OPT": "/DWIN32 /D_WINDOWS /GR /EHsc /fp:strict /permissive-",
				"CXX_OPT": "/DWIN32 /D_WINDOWS /GR /EHsc /permissive-",
				"VCPKG_ROOT":  "C:/Tools/vcpkg"
			},
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "$env{CXX_WARNINGS} $env{CXX_OPT}",
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET":  "x64-windows-static-md"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	],
	"buildPresets": [
		{
			"name": "vs-build",
			"hidden": true,
			"configurePreset": "vs2022",
			"jobs": 4,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "vs2022-release",
			"displayName": "Release",
			"inherits": "vs-build",
			"configuration": "Release"
		},
		{
			"name": "vs2022-debug",
			"displayName": "Debug",
			"inherits": "vs-build",
			"configuration": "Debug"
		},
		{
			"name": "clang-cl-debug",
			"displayName": "Debug",
			"configurePreset": "clang-cl-debug",
			"configuration": "Debug",
			"jobs": 4,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "clang-cl-release",
			"displayName": "Release",
			"configurePreset": "clang-cl-release",
			"configuration": "Release",
			"jobs": 4,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	]
}
